# Copy this file to .env and replace every placeholder before running the agent.

IMAP_SERVER=imap.gmail.com
EMAIL_ACCOUNT=your_email@gmail.com
APP_PASSWORD=your_16_digit_app_password
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Examples:
# Ollama: http://127.0.0.1:11434/api/generate
# Jan: http://127.0.0.1:1337/api/generate
LLM_API_URL=http://127.0.0.1:11434/api/generate
MODEL_NAME=qwen2.5:7b-instruct

INBOX_FOLDER=inbox
EMAIL_FROM_FILTER=alert@indeed.com

DATABASE_PATH=jobs.db
QUEUE_DIR=queue
CHROME_PROFILE_DIR=chrome-profile
CANDIDATE_PROFILE_PATH=candidate_profile.md
START_URL=https://www.indeed.com/account/login
LOG_PATH=job_agent.log
MATCH_THRESHOLD=75
PLAYWRIGHT_NAV_TIMEOUT_MS=20000
PLAYWRIGHT_TEXT_TIMEOUT_MS=8000
LLM_REQUEST_TIMEOUT_SECONDS=60
JOB_DELAY_SECONDS=1.5

# Optional. Leave blank if wkhtmltopdf is already on PATH.
WKHTMLTOPDF_PATH=
